run = "cd baths-engine/backend && pip install -r requirements.txt && python -m uvicorn main:app --host 0.0.0.0 --port 8080"
modules = ["python-3.11", "nodejs-20"]

[nix]
channel = "stable-22_11"
packages = ["libxcrypt"]

[deployment]
run = ["sh", "-c", "cd baths-engine/backend && pip install -r requirements.txt && python -m uvicorn main:app --host 0.0.0.0 --port 8080"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "BATHS Game Engine"

[[workflows.workflow]]
name = "BATHS Game Engine"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/baths-engine && python backend/main.py & cd /home/runner/workspace/baths-engine/frontend && npm run dev"
waitForPort = 5000

[[ports]]
localPort = 9000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80
