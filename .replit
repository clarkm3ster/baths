run = "cd baths-engine/backend && pip install -r requirements.txt && python -m uvicorn main:app --host 0.0.0.0 --port 8080"
modules = ["python-3.11", "nodejs-20"]

[nix]
channel = "stable-22_11"
packages = ["libxcrypt"]

[deployment]
run = ["sh", "-c", "cd baths-engine/backend && pip install -r requirements.txt && python -m uvicorn main:app --host 0.0.0.0 --port 8080"]

[agent]
expertMode = true
